# Copy to .env.migration.test or .env.migration.prod and fill in values. Do not commit secrets.
# Stage (test|prod) is chosen by: python migration/migrate_data.py --env test|prod (not set in this file).

# --- Source (national RDS, typically no TLS) ---
SOURCE_HOST=your-rds.region.rds.amazonaws.com
SOURCE_PORT=3306
SOURCE_USER=readonly_user
SOURCE_PASSWORD=
SOURCE_TLS_ENABLED=false

# --- Target (TiDB Cloud, TLS required) ---
TARGET_HOST=gateway.tidbcloud.com
TARGET_PORT=4000
TARGET_USER=
TARGET_PASSWORD=
TARGET_TLS_ENABLED=true

# --- Throttling & batching ---
READ_DELAY_SECONDS=1
SCHEMA_DELAY_SECONDS=5
BATCH_SIZE=500
MAX_RETRIES=10
BACKOFF_BASE_SECONDS=2
BACKOFF_MAX_SECONDS=60

# Bare schema names (no stage suffix). migrate_data appends _<stage> from --env (bootstrap + widen + encrypt).
PAXMINER_SCHEMA=paxminer
WEASELBOT_SCHEMA=weaselbot
SLACKBLAST_SCHEMA=slackblast
QSIGNUPS_SCHEMA=qsignups

# Checkpoint file path (optional)
CHECKPOINT_FILE=migration_checkpoint.json

# Structured audit receipt (JSON): per-schema status, failed SQL, MySQL error codes
MIGRATION_REPORT_FILE=migration_report.json

# Human-readable summary is also written to migration/receipts/migration-{env}-{timestamp}.txt (gitignored)

# Optional: encrypt DB fields after copy (same value as app DB_ENCRYPTION_KEY; if set, min 16 chars — Lambdas require this at runtime)
# DB_ENCRYPTION_KEY=

# S3 bucket for backblast images (same name as deploy IMAGE_S3_BUCKET). Required for migrate_images.py --env …
# Optional on migrate_data.py --env … (if set, images run at end of full migration too).
# IMAGE_S3_BUCKET=your-globally-unique-bucket-name
