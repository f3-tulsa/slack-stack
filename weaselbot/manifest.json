{
  "display_information": {
    "name": "WeaselBot",
    "description": "Achievements and Kotter reports for your F3 Region.",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "WeaselBot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/kotter-report",
        "url": "__HOSTNAME__",
        "description": "Open Kotter report controls",
        "usage_hint": "/kotter-report"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:join",
        "channels:read",
        "chat:write",
        "files:read",
        "files:write",
        "im:read",
        "reactions:write",
        "users:read",
        "users:read.email",
        "channels:history",
        "commands"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "__HOSTNAME__"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
