export SLACK_SIGNING_SECRET=your-signing-secret
export SLACK_BOT_TOKEN=your-bot-token
export DATABASE_HOST=localhost
export DATABASE_PORT=3306
export DATABASE_TLS_ENABLED=false
export ADMIN_DATABASE_USER=root
export ADMIN_DATABASE_PASSWORD=your-db-password
export ADMIN_DATABASE_SCHEMA=slackblast
export PAXMINER_SCHEMA=paxminer
export LOCAL_DEV_REGION_SCHEMA=f3devregion
# Shared DB encryption (same passphrase as DB_ENCRYPTION_KEY in SAM / other apps)
export DB_ENCRYPTION_KEY=your-passphrase-or-leave-empty-for-plaintext
export TIMEZONE=US/Central
# S3 bucket for backblast uploads / static images (must exist or use deployed stack bucket name)
export IMAGE_S3_BUCKET=your-image-bucket-name
export STRAVA_CLIENT_ID=your-strava-client-id
export STRAVA_CLIENT_SECRET=your-strava-client-secret
# Slack OAuth (install flow) uses MySQL tables in ADMIN_DATABASE_SCHEMA when not in local dev
export AWS_ACCESS_KEY_ID=your-aws-access-key-id
export AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key