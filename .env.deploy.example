# Copy to .env.deploy.test or .env.deploy.prod and fill in (see README).
# Used by ./deploy.sh --env test|prod

# F3 Region name andSlack workspace Team ID (e.g. T01234567), use the right one for test or prod
F3_REGION_NAME=
F3_REGION_SLACK_TEAM_ID=

# Select an AWS Region where resources should be deployed
AWS_REGION=us-east-1

# --- Bootstrap (one-time OIDC + SAM artifact bucket; use ./deploy.sh --env test --bootstrap) ---
BOOTSTRAP_STACK_NAME=slack-stack-bootstrap
CREATE_OIDC_PROVIDER=true
DEPLOY_BUCKET_PREFIX=slack-stack-deploy

# DB connection info (same across all apps)
DATABASE_HOST=gateway.tidbcloud.com
DATABASE_PORT=4000
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_TLS_ENABLED=true

# Shared DB field encryption (required for deploy and Lambdas; min 16 chars; same across all apps)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# Bare schema names only. deploy.sh and GitHub Actions append _<stage> from --env / branch (e.g. paxminer_test)
# so they match migration output (paxminer_test, slackblast_prod, etc.).
PAXMINER_SCHEMA=paxminer
WEASELBOT_SCHEMA=weaselbot
SLACKBLAST_SCHEMA=slackblast
QSIGNUPS_SCHEMA=qsignups

# Globally unique S3 bucket name (slackblast stack creates this bucket)
# Optional: if set, GitHub Actions OIDC role can manage this bucket (must match IMAGE_S3_BUCKET)
# Leave empty only if you manage S3 policy separately
IMAGE_S3_BUCKET=slack-stack-f3region-bucket-stage

# PAXminer / Weaselbot — passed to SAM; Lambdas encrypt and upsert into DB at cold start (see README)
PM_SLACK_TOKEN=
WB_SLACK_TOKEN=
# Optional: achievements Lambda only — comma-separated regional schema names (e.g. f3ttown_prod). Unset = all f3-prefixed regions.
# QSignups also uses this (first schema only) for Site Q: read/write site_q_user_id on {schema}.aos (Weaselbot Kotter reports).
WEASELBOT_PAXMINER_REGIONAL_SCHEMAS=

# slackblast Lambda / Slack app
SB_SLACK_TOKEN=
SB_SLACK_SIGNING_SECRET=
SB_SLACK_CLIENT_ID=        # GitHub Actions: set as environment variable (not secret); public app id
SB_SLACK_CLIENT_SECRET=
# Optional: Strava OAuth credentials for Slackblast (see README)
# SB_STRAVA_CLIENT_ID=
# SB_STRAVA_CLIENT_SECRET=
# Optional: set to "true" on first deploy to create OAuth tables; leave unset or "false" for normal deploys
# SB_CREATE_OAUTH_TABLES=false

# qsignups Lambda / Slack app (separate Slack app)
QS_SLACK_TOKEN=
QS_SLACK_SIGNING_SECRET=
QS_SLACK_CLIENT_ID=        # GitHub Actions: set as environment variable (not secret); public app id
QS_SLACK_CLIENT_SECRET=
# Optional: Google OAuth credentials for QSignups (see README)
# QS_GOOGLE_CLIENT_ID=
# QS_GOOGLE_CLIENT_SECRET=
# Optional: set to "true" on first deploy to create OAuth tables; leave unset or "false" for normal deploys
# QS_CREATE_OAUTH_TABLES=false

# Optional: OIDC deploy role ARN for ./deploy.sh --setup-github (if empty, read from bootstrap stack outputs)
# AWS_ROLE_ARN=

# Optional: SAM artifact bucket override (bootstrap stack output DeploymentBucketName).
# If unset, deploy.sh reads DeploymentBucketName from BOOTSTRAP_STACK_NAME (same as GitHub Actions).
# Only use --resolve-s3 as last resort — the OIDC deploy role is not allowed on SAM's default bucket.
# DEPLOYMENT_S3_BUCKET=

# --- Optional deploy speed / cost (GitHub: set same names as Environment variables) ---
# SAM_NO_CACHE=true          # force full sam build --no-cached (CI and deploy.sh); default is cached builds
# SKIP_SMOKE_TEST=true       # skip post-deploy PAXminer sync + Weaselbot achievements invokes (CI + deploy.sh --skip-smoke-test)
# RUN_EXTEND_SCHEDULE=true   # run QSignups extend-schedule custom resource on deploy (changing nonce); default skips for fast deploys
# ENABLE_XRAY=true           # turn on X-Ray for slackblast + qsignups stacks (default off / PassThrough)
