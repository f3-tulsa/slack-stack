# Copy to .env.deploy.test or .env.deploy.prod and fill in (see README).
# Used by ./deploy.sh --env test|prod

AWS_REGION=us-east-2
# SAM Stage mapping: test or prod (must match StagesMap in slackblast/qsignups templates)
STAGE=test

# --- Bootstrap (one-time OIDC + SAM artifact bucket; use ./deploy.sh --env test --bootstrap) ---
BOOTSTRAP_STACK_NAME=slack-stack-bootstrap
CREATE_OIDC_PROVIDER=true
DEPLOY_BUCKET_PREFIX=slack-stack-deploy
# Optional: if set, GitHub Actions OIDC role can manage this bucket (must match IMAGE_S3_BUCKET)
# Leave empty only if you manage S3 policy separately

DATABASE_HOST=
DATABASE_PORT=4000
DATABASE_USER=
DATABASE_PASSWORD=

# Shared DB field encryption (same across all apps)
DB_ENCRYPTION_KEY=

# Bare schema names only. deploy.sh and GitHub Actions append _${STAGE} (e.g. paxminer_test)
# so they match migration output (paxminer_test, slackblast_prod, etc.).
PAXMINER_SCHEMA=paxminer
WEASELBOT_SCHEMA=weaselbot
SLACKBLAST_SCHEMA=slackblast
QSIGNUPS_SCHEMA=qsignups

# Globally unique S3 bucket name (slackblast stack creates this bucket)
IMAGE_S3_BUCKET=slack-stack-images-test

# PAXminer / Weaselbot: Slack tokens are read from the DB (paxminer.regions), not passed to SAM.
# No PM_* / WB_* env vars are required for deploy.

# slackblast Lambda / Slack app
SB_SLACK_TOKEN=
SB_SLACK_SIGNING_SECRET=
SB_SLACK_CLIENT_SECRET=
SB_STRAVA_CLIENT_ID=
SB_STRAVA_CLIENT_SECRET=

# qsignups Lambda / Slack app (separate Slack app)
QS_SLACK_TOKEN=
QS_SLACK_SIGNING_SECRET=
QS_SLACK_CLIENT_SECRET=
QS_GOOGLE_CLIENT_ID=
QS_GOOGLE_CLIENT_SECRET=

# Optional: OIDC deploy role ARN for ./deploy.sh --setup-github (if empty, read from bootstrap stack outputs)
# AWS_ROLE_ARN=

# Optional: SAM artifact bucket (bootstrap stack output DeploymentBucketName). If unset, uses bootstrap
# output when you pass --bootstrap in the same run, otherwise sam deploy uses --resolve-s3.
# DEPLOYMENT_S3_BUCKET=
